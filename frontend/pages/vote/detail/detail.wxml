<!--pages/vote/detail/detail.wxml-->
<view class="container">
  <!-- жҠ•зҘЁдҝЎжҒҜ -->
  <view class="vote-card">
    <view class="vote-header">
      <text class="vote-title">{{voteDetail.title}}</text>
      <text class="vote-status {{voteDetail.status}}">{{voteDetail.status === 'active' ? 'иҝӣиЎҢдё? : 'е·Із»“жқ?}}</text>
    </view>

    <view class="vote-desc">{{voteDetail.description}}</view>

    <view class="vote-info-row">
      <text class="info-label">рҹ“… ејҖе§Ӣж—¶й—ҙпјҡ</text>
      <text class="info-value">{{voteDetail.start_time | formatDate}}</text>
    </view>

    <view class="vote-info-row">
      <text class="info-label">рҹ“… з»“жқҹж—¶й—ҙпј?/text>
      <text class="info-value">{{voteDetail.end_time | formatDate}}</text>
    </view>

    <view class="vote-info-row">
      <text class="info-label">рҹ“Ҡ е·ІжҠ•зҘЁпјҡ</text>
      <text class="info-value highlight">{{voteDetail.total_votes}}зҘ?/text>
    </view>

    <view class="vote-info-row">
      <text class="info-label">рҹ“қ жҠ•зҘЁзұ»еһӢпј?/text>
      <text class="info-value">{{voteDetail.vote_type === 'single' ? 'еҚ•йҖ? : 'еӨҡйҖ?}}пјҲ{{voteDetail.min_votes}}-{{voteDetail.max_votes}}зҘЁпјү</text>
    </view>
  </view>

  <!-- жҠ•зҘЁйҖүйЎ№ -->
  <view class="options-card" wx:if="{{voteDetail.status === 'active' && !voteDetail.has_voted}}">
    <view class="card-title">иҜ·йҖүжӢ©жӮЁзҡ„ж„Ҹи§Ғ</view>

    <view class="options-list">
      <view 
        class="option-item {{selectedOptions.includes(item) ? 'selected' : ''}}" 
        wx:for="{{voteDetail.options}}" 
        wx:key="*this"
        bindtap="toggleOption"
        data-option="{{item}}"
      >
        <view class="option-radio">
          <view class="radio-dot {{selectedOptions.includes(item) ? 'checked' : ''}}"></view>
        </view>
        <text class="option-text">{{item}}</text>
      </view>
    </view>

    <view class="selected-count">е·ІйҖүжӢ© {{selectedOptions.length}} йЎ№пјҲ{{voteDetail.min_votes}}-{{voteDetail.max_votes}}пј?/view>

    <button 
      class="submit-btn" 
      bindtap="submitVote"
      disabled="{{!canSubmit}}"
    >
      жҸҗдәӨжҠ•зҘЁ
    </button>
  </view>

  <!-- е·ІжҠ•зҘЁжҸҗзӨ?-->
  <view class="voted-card" wx:if="{{voteDetail.has_voted}}">
    <view class="voted-icon">вң?/view>
    <text class="voted-text">жӮЁе·ІжҠ•иҝҮзҘ?/text>
    <text class="voted-desc">жҜҸдёӘдёҡдё»еҸӘиғҪжҠ•зҘЁдёҖж¬?/text>
    <button class="view-result-btn" bindtap="viewResult">жҹҘзңӢз»“жһң</button>
  </view>

  <!-- жҠ•зҘЁз»“жһң -->
  <view class="result-card" wx:if="{{showResult}}">
    <view class="card-title">рҹ“Ҡ жҠ•зҘЁз»“жһң</view>

    <view class="result-list">
      <view class="result-item" wx:for="{{voteResults}}" wx:key="option">
        <text class="result-option">{{item.option}}</text>
        <view class="result-bar">
          <view class="result-fill" style="width: {{item.percentage * 100}}%"></view>
        </view>
        <view class="result-stats">
          <text class="result-count">{{item.count}}зҘ?/text>
          <text class="result-percent">{{item.percentageText}}%</text>
        </view>
      </view>
    </view>

    <view class="result-summary">
      <text class="summary-label">жҖ»жҠ•зҘЁж•°пј?/text>
      <text class="summary-value">{{voteResults.total_votes}}зҘ?/text>
    </view>

    <view class="result-summary" wx:if="{{voteResults.passed !== null}}">
      <text class="summary-label">жҠ•зҘЁз»“жһңпј?/text>
      <text class="summary-value {{voteResults.passed ? 'pass' : 'fail'}}">
        {{voteResults.passed ? 'вң?е·ІйҖҡиҝҮ' : 'вқ?жңӘйҖҡиҝҮ'}}
      </text>
    </view>
  </view>

  <!-- е§”жүҳжҠ•зҘЁ -->
  <view class="proxy-card" wx:if="{{voteDetail.status === 'active' && !voteDetail.has_voted}}">
    <view class="card-title">рҹ‘Ҙ е§”жүҳжҠ•зҘЁ</view>
    <text class="proxy-desc">еҰӮж— жі•еҸӮдёҺжҠ•зҘЁпјҢеҸҜе§”жүҳе…¶д»–дёҡдё»д»ЈдёәжҠ•зҘ?/text>
    <button class="proxy-btn" bindtap="assignProxy">и®ҫзҪ®е§”жүҳдә?/button>
  </view>
</view>
