<!--pages/vote/detail/detail.wxml-->
<view class="container">
  <view class="vote-card">
    <view class="vote-header">
      <text class="vote-title">{{voteDetail.title}}</text>
      <text class="vote-status">{{voteDetail.statusText}}</text>
    </view>
    <view class="vote-info-row">
      <text class="info-label">开始时间：</text>
      <text class="info-value">{{voteDetail.startTimeText}}</text>
    </view>
    <view class="vote-info-row">
      <text class="info-label">结束时间：</text>
      <text class="info-value">{{voteDetail.endTimeText}}</text>
    </view>
    <view class="vote-info-row">
      <text class="info-label">已投票：</text>
      <text class="info-value">{{voteDetail.totalVotes}}票</text>
    </view>
  </view>
  <view class="options-card" wx:if="{{voteDetail.status=='active' && !voteDetail.hasVoted}}">
    <view class="options-list">
      <view class="option-item" wx:for="{{voteDetail.options}}" wx:key="*this" bindtap="toggleOption">
        <text class="option-text">{{item}}</text>
      </view>
    </view>
    <button class="submit-btn" bindtap="submitVote">提交投票</button>
  </view>
  <view class="result-card" wx:if="{{showResult}}">
    <view class="result-item" wx:for="{{voteResults}}" wx:key="option">
      <text class="result-option">{{item.option}}</text>
      <text class="result-count">{{item.count}}票 ({{item.percentageText}}%)</text>
    </view>
  </view>
</view>