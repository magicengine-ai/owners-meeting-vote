<!--pages/auth/login/login.wxml-->
<view class="login-container">
  <!-- Logo 和欢迎语 -->
  <view class="header">
    <view class="logo">🏠</view>
    <text class="title">业主大会投票</text>
    <text class="subtitle">安全、透明、便捷的投票系统</text>
  </view>

  <!-- 登录方式选择 -->
  <view class="login-tabs">
    <view 
      class="tab {{currentTab === 'wechat' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="wechat"
    >
      微信登录
    </view>
    <view 
      class="tab {{currentTab === 'phone' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="phone"
    >
      手机号登录
    </view>
  </view>

  <!-- 微信登录 -->
  <view class="login-content" wx:if="{{currentTab === 'wechat'}}">
    <view class="wechat-login">
      <button 
        class="wechat-btn" 
        type="primary" 
        bindtap="wechatLogin"
        open-type="getUserInfo"
      >
        <text class="wechat-icon">💬</text>
        <text>微信一键登录</text>
      </button>
      
      <view class="tips">
        <text>微信登录将自动获取您的微信昵称和头像</text>
      </view>
    </view>
  </view>

  <!-- 手机号登录 -->
  <view class="login-content" wx:if="{{currentTab === 'phone'}}">
    <view class="phone-login">
      <!-- 手机号输入 -->
      <view class="input-group">
        <text class="input-label">📱 手机号</text>
        <input 
          class="input" 
          type="number" 
          maxlength="11" 
          placeholder="请输入手机号" 
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <!-- 验证码输入 -->
      <view class="input-group">
        <text class="input-label">🔐 验证码</text>
        <view class="code-input-group">
          <input 
            class="input code-input" 
            type="number" 
            maxlength="6" 
            placeholder="6 位验证码" 
            value="{{smsCode}}"
            bindinput="onCodeInput"
          />
          <button 
            class="send-code-btn {{canSendCode ? '' : 'disabled'}}" 
            bindtap="sendSmsCode"
            disabled="{{!canSendCode}}"
          >
            {{sendCodeText}}
          </button>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button 
        class="login-btn" 
        type="primary" 
        bindtap="phoneLogin"
        disabled="{{!canPhoneLogin}}"
      >
        登录
      </button>

      <view class="tips">
        <text>登录即代表您同意</text>
        <text class="link" bindtap="showAgreement">《用户协议》</text>
        <text>和</text>
        <text class="link" bindtap="showPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer">
    <text class="footer-text">本小程序仅用于业主大会投票</text>
    <text class="footer-text">需要完成房产证认证后才能参与投票</text>
  </view>
</view>
