<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- з”ЁжҲ·дҝЎжҒҜеҚЎзүҮ -->
  <view class="user-card">
    <view class="user-info">
      <image 
        wx:if="{{userInfo.avatar_url}}" 
        class="avatar" 
        src="{{userInfo.avatar_url}}" 
        mode="aspectFill"
      ></image>
      <view wx:else class="avatar-default">
        <text class="avatar-icon">рҹ‘Ө</text>
      </view>
      
      <view class="user-details">
        <text class="nickname">{{userInfo.nickname || 'еҫ®дҝЎз”ЁжҲ·'}}</text>
        <text class="phone" wx:if="{{userInfo.phone}}">рҹ“ұ {{userInfo.phone}}</text>
        <text class="openid" wx:if="{{!userInfo.nickname && !userInfo.phone}}">ID: {{userInfo.openidSubstring}}...</text>
      </view>
    </view>
    
    <!-- и®ӨиҜҒзҠ¶жҖ?-->
    <view class="verify-status" bindtap="goToVerify">
      <view class="status-badge {{verifyStatus}}">
        <text class="badge-icon">{{verifyStatus === 'approved' ? 'вң? : verifyStatus === 'pending' ? 'вҸ? : 'вҡ пёҸ'}}</text>
        <text class="badge-text">{{verifyText}}</text>
      </view>
      <text class="arrow">вҖ?/text>
    </view>
  </view>

  <!-- еҠҹиғҪиҸңеҚ• -->
  <view class="menu-section">
    <text class="section-title">жҲ‘зҡ„жңҚеҠЎ</text>
    
    <view class="menu-list">
      <!-- жҲ‘зҡ„жҠ•зҘЁ -->
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/vote/list">
        <view class="menu-icon">рҹ—іпё?/view>
        <text class="menu-text">жҲ‘зҡ„жҠ•зҘЁ</text>
        <text class="menu-badge" wx:if="{{voteCount > 0}}">{{voteCount}}</text>
        <text class="arrow">вҖ?/text>
      </view>

      <!-- жҲ‘зҡ„дјҡи®® -->
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/meeting/list">
        <view class="menu-icon">рҹ“Ӣ</view>
        <text class="menu-text">жҲ‘зҡ„дјҡи®®</text>
        <text class="menu-badge" wx:if="{{meetingCount > 0}}">{{meetingCount}}</text>
        <text class="arrow">вҖ?/text>
      </view>

      <!-- жҲ‘зҡ„жҲҝдә§ -->
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/profile/property">
        <view class="menu-icon">рҹҸ </view>
        <text class="menu-text">жҲ‘зҡ„жҲҝдә§</text>
        <view class="menu-extra">
          <text class="extra-text" wx:if="{{propertyInfo}}">{{propertyInfo.addressSubstring}}...</text>
          <text class="extra-text" wx:else>жңӘи®ӨиҜ?/text>
        </view>
        <text class="arrow">вҖ?/text>
      </view>

      <!-- ж¶ҲжҒҜйҖҡзҹҘ -->
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/profile/notifications">
        <view class="menu-icon">рҹ””</view>
        <text class="menu-text">ж¶ҲжҒҜйҖҡзҹҘ</text>
        <text class="menu-badge" wx:if="{{noticeCount > 0}}">{{noticeCount}}</text>
        <text class="arrow">вҖ?/text>
      </view>
    </view>
  </view>

  <!-- и®ҫзҪ® -->
  <view class="menu-section">
    <text class="section-title">и®ҫзҪ®</text>
    
    <view class="menu-list">
      <!-- е…ідәҺжҲ‘д»¬ -->
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon">в„№пёҸ</view>
        <text class="menu-text">е…ідәҺжҲ‘д»¬</text>
        <text class="arrow">вҖ?/text>
      </view>

      <!-- её®еҠ©дёҺеҸҚйҰ?-->
      <view class="menu-item" bindtap="showFeedback">
        <view class="menu-icon">вқ?/view>
        <text class="menu-text">её®еҠ©дёҺеҸҚйҰ?/text>
        <text class="arrow">вҖ?/text>
      </view>
    </view>
  </view>

  <!-- йҖҖеҮәзҷ»еҪ?-->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">йҖҖеҮәзҷ»еҪ?/button>
  </view>

  <!-- еә•йғЁдҝЎжҒҜ -->
  <view class="footer">
    <text class="version">зүҲжң¬еҸ·пјҡv1.0.0</text>
    <text class="copyright">В© 2026 дёҡдё»еӨ§дјҡжҠ•зҘЁзі»з»ҹ</text>
  </view>
</view>
