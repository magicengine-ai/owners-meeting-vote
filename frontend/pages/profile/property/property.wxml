<!--pages/profile/property/property.wxml-->
<view class="property-container">
  <!-- 房产信息卡片 -->
  <view class="property-card">
    <view class="card-header">
      <text class="card-icon">🏠</text>
      <text class="card-title">房产信息</text>
    </view>

    <view class="card-content" wx:if="{{propertyInfo}}">
      <view class="info-item">
        <text class="info-label">产权人</text>
        <text class="info-value">{{propertyInfo.owner_name}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">房产证号</text>
        <text class="info-value">{{propertyInfo.cert_number}}</text>
      </view>

      <view class="info-item">
        <text class="info-label">房屋地址</text>
        <text class="info-value">{{propertyInfo.address}}</text>
      </view>

      <view class="info-item" wx:if="{{propertyInfo.area}}">
        <text class="info-label">建筑面积</text>
        <text class="info-value">{{propertyInfo.area}}㎡</text>
      </view>

      <view class="info-item">
        <text class="info-label">认证状态</text>
        <text class="info-value status-text {{verifyStatus}}">{{verifyText}}</text>
      </view>

      <view class="info-item" wx:if="{{propertyInfo.verified_at}}">
        <text class="info-label">认证时间</text>
        <text class="info-value">{{propertyInfo.verified_at}}</text>
      </view>
    </view>

    <view class="card-empty" wx:else>
      <text class="empty-icon">⚠️</text>
      <text class="empty-text">暂无房产信息</text>
      <text class="empty-desc">请先完成身份认证</text>
      <button class="verify-btn" bindtap="goToVerify">去认证</button>
    </view>
  </view>

  <!-- 投票权信息 -->
  <view class="vote-rights-card">
    <view class="card-header">
      <text class="card-icon">🗳️</text>
      <text class="card-title">投票权信息</text>
    </view>

    <view class="vote-content">
      <view class="vote-item">
        <text class="vote-label">投票权数</text>
        <text class="vote-value">{{voteRights}}</text>
      </view>

      <view class="vote-item">
        <text class="vote-label">投票权比例</text>
        <text class="vote-value">{{votePercent}}%</text>
      </view>

      <view class="vote-desc">
        <text>投票权根据房产证面积计算，每 1㎡计 1 票</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="reverify-btn" bindtap="reVerify" wx:if="{{verifyStatus === 'rejected'}}">
      重新认证
    </button>
  </view>
</view>
