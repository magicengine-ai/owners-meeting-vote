/* pages/profile/property/property.wxss */

.property-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

/* Property Card */
.property-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.card-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.card-content {
  padding: 40rpx 30rpx;
}

.info-item {
  margin-bottom: 30rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.info-value {
  display: block;
  font-size: 30rpx;
  color: #333333;
  word-break: break-all;
}

.info-value.status-text {
  font-weight: 500;
}

.info-value.status-text.approved {
  color: #07c160;
}

.info-value.status-text.pending {
  color: #ff9500;
}

.info-value.status-text.rejected {
  color: #ff4444;
}

/* Empty State */
.card-empty {
  padding: 80rpx 30rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.verify-btn {
  width: 300rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 30rpx;
  margin: 0 auto;
}

/* Vote Rights Card */
.vote-rights-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.vote-content {
  padding: 40rpx 30rpx;
}

.vote-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.vote-item:last-child {
  margin-bottom: 0;
}

.vote-label {
  font-size: 30rpx;
  color: #666666;
}

.vote-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.vote-desc {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.vote-desc text {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

/* Action Section */
.action-section {
  padding: 40rpx 30rpx;
}

.reverify-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}
