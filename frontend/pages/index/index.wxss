/* pages/index/index.wxss */
.container {
  padding: 20rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.card-more {
  font-size: 24rpx;
  color: #999999;
}

/* 公告列表 */
.notice-list {
  padding: 10rpx 0;
}

.notice-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.notice-date {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 投票列表 */
.vote-list {
  padding: 10rpx 0;
}

.vote-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.vote-item:last-child {
  border-bottom: none;
}

.vote-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 15rpx;
}

.vote-progress {
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 5rpx;
}

.progress-fill {
  height: 100%;
  background-color: #4A90E2;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
}

.vote-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 会议列表 */
.meeting-list {
  padding: 10rpx 0;
}

.meeting-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meeting-item:last-child {
  border-bottom: none;
}

.meeting-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.meeting-info {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 5rpx;
}
