# 业主大会投票小程序 - 环境配置示例
# 复制此文件为 .env 并填入实际配置

# ============================================
# 数据库配置
# ============================================
DB_HOST=db
DB_PORT=5432
DB_NAME=vote_db
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT 配置
# ============================================
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# 微信小程序配置
# ============================================
# 在微信公众平台获取：https://mp.weixin.qq.com/
WECHAT_APP_ID=wx0000000000000000
WECHAT_APP_SECRET=your_wechat_app_secret_here

# ============================================
# OCR 配置（百度 AI）
# ============================================
# 在百度 AI 开放平台获取：https://ai.baidu.com/
OCR_APP_ID=your_baidu_app_id
OCR_API_KEY=your_baidu_api_key
OCR_SECRET_KEY=your_baidu_secret_key

# ============================================
# 区块链配置（百度 X-Chains）
# ============================================
# 在百度 X-Chains 平台获取：https://xchain.baidu.com/
CHAIN_ENDPOINT=https://xchain.baidu.com
CHAIN_CHAIN_ID=your_chain_id_here
CHAIN_APP_ID=your_app_id
CHAIN_APP_KEY=your_app_key

# ============================================
# 短信配置（阿里云）
# ============================================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your_sms_access_key
SMS_SECRET_KEY=your_sms_secret_key
SMS_SIGN_NAME=业主大会投票
SMS_TEMPLATE_CODE=SMS_000000000

# ============================================
# 应用配置
# ============================================
DEBUG=true
ENVIRONMENT=development
APP_NAME=业主大会投票小程序
APP_VERSION=1.0.0

# ============================================
# 服务器配置
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","https://your-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# ============================================
# 缓存配置
# ============================================
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_REDIS_URL=redis://redis:6379/0

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STRICT=10/minute
